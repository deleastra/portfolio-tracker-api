# Application
APP_PORT=8080
APP_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=portfolio
DB_PASSWORD=portfolio
DB_NAME=portfolio
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# Yahoo Finance
YAHOO_FINANCE_BASE_URL=https://query1.finance.yahoo.com
YAHOO_PRICE_CACHE_TTL=15m

# Rate limiter for batch historical fetch
PRICE_LOADER_WORKERS=3
PRICE_LOADER_BASE_BACKOFF_MS=1000
PRICE_LOADER_MAX_BACKOFF_MS=32000
